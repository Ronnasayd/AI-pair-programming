{
  "general": {
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d",
      "warningAcknowledged": true
    },
    "preferredEditor": "vscode",
    "vimMode": false,
    "plan": {
      "directory": "docs/agents/plans/"
    }
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    },
    "enablePermanentToolApproval": true,
    "autoAddToPolicyByDefault": true,
    "enableConseca": false
  },
  "mcpServers": {
    "figma": {
      "url": "https://mcp.figma.com/mcp",
      "type": "http"
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "atlassian": {
      "type": "http",
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "mcp-manager": {
      "command": "/home/ronnas/develop/personal/mcp-manager/venv/bin/mcp-manager",
      "args": [
        "--config",
        "/home/ronnas/develop/personal/mcp-manager/backends.json",
        "--catalog",
        "/home/ronnas/develop/personal/mcp-manager/catalog.json",
        "--transport",
        "stdio"
      ],
      "type": "stdio"
    }
  },
  "ide": {
    "hasSeenNudge": true,
    "enabled": true
  },
  "experimental": {
    "enableAgents": true,
    "plan": true,
    "directWebFetch": true
  },
  "ui": {
    "inlineThinkingMode": "full",
    "showMemoryUsage": true,
    "showUserIdentity": true,
    "footer": {
      "hideContextPercentage": false
    },
    "showCitations": true,
    "showModelInfoInChat": true,
    "showStatusInTitle": true,
    "useAlternateBuffer": true,
    "errorVerbosity": "full"
  },
  "model": {
    "name": ""
  },
  "context": {
    "fileFiltering": {
      "respectGitIgnore": false
    },
    "loadMemoryFromIncludeDirectories": false
  },
  "checkpointing": {
    "enabled": true
  },
  "billing": {
    "overageStrategy": "ask"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.gemini/hooks/scripts/session_start.py",
            "description": "Log the session start to a file for auditing purposes."
          },
          {
            "type": "command",
            "command": "$HOME/.gemini/hooks/scripts/memory.py",
            "description": "Provide useful memory for agents, such as relevant documentation files in the repository and the latest session information."
          }
        ]
      }
    ],
    "SessionEnd": [],
    "BeforeAgent": [],
    "AfterAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "session_end",
            "type": "command",
            "command": "$HOME/.gemini/hooks/scripts/session_end.py",
            "description": "Log the session end to a file for auditing purposes."
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "log-tool-calls",
            "type": "command",
            "command": "$HOME/.gemini/hooks/scripts/log_tools_call.py",
            "description": "Log the tool usage to a file for auditing purposes."
          },
          {
            "name": "protect-files",
            "type": "command",
            "command": "$HOME/.gemini/hooks/scripts/protect_files.py",
            "description": "Protect sensitive files from being modified or deleted."
          }
        ]
      }
    ],
    "AfterTool": [],
    "PreCompress": [],
    "Notification": [],
    "BeforeModel": [],
    "AfterModel": []
  }
}