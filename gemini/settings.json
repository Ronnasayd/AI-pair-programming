{
  "general": {
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d",
      "warningAcknowledged": true
    },
    "preferredEditor": "vscode",
    "vimMode": false,
    "plan": {
      "directory": "docs/agents/plans/"
    }
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    },
    "enablePermanentToolApproval": true,
    "autoAddToPolicyByDefault": true,
    "enableConseca": true
  },
  "mcpServers": {
    "sequentialthinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "taskmaster-ai": {
      "command": "npx",
      "args": [
        "-y",
        "-p",
        "@modelcontextprotocol/sdk@1.17.2",
        "-p",
        "fastmcp@3.23.0",
        "-p",
        "task-master-ai",
        "task-master-ai"
      ],
      "env": {
        "TASK_MASTER_ALLOW_METADATA_UPDATES": "true"
      }
    },
    "my-mcp-server": {
      "command": "my_mcp_server",
      "args": []
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "sonarqube": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "SONARQUBE_TOKEN",
        "-e",
        "SONARQUBE_URL",
        "--network",
        "host",
        "mcp/sonarqube"
      ],
      "env": {
        "SONARQUBE_URL": "http://localhost:9000"
      }
    },
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp"
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "chrome-devtools-mcp@latest"
      ]
    },
    "exa": {
      "type": "http",
      "url": "https://mcp.exa.ai/mcp"
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    }
  },
  "ide": {
    "hasSeenNudge": true,
    "enabled": true
  },
  "experimental": {
    "enableAgents": true,
    "plan": true,
    "directWebFetch": true
  },
  "ui": {
    "inlineThinkingMode": "full",
    "showMemoryUsage": true,
    "showUserIdentity": true,
    "footer": {
      "hideContextPercentage": false
    },
    "showCitations": true,
    "showModelInfoInChat": true,
    "showStatusInTitle": true,
    "useAlternateBuffer": true
  },
  "model": {
    "name": ""
  },
  "context": {
    "fileFiltering": {
      "respectGitIgnore": false
    }
  },
  "checkpointing": {
    "enabled": true
  },
  "billing": {
    "overageStrategy": "ask"
  }
}