{
  "enabledMcpjsonServers": [
    "figma",
    "github",
    "atlassian",
    "mcp-manager",
    "postgresql",
    "mysql",
    "mongodb",
    "sqlite"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/scripts/log_tools_call.py"
          },
          {
            "type": "command",
            "command": ".claude/hooks/scripts/protect_files.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/scripts/quality_gate.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/scripts/session_start.py"
          },
          {
            "type": "command",
            "command": ".claude/hooks/scripts/memory.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/scripts/session_end.py"
          }
        ]
      }
    ],
    "PreCompact": [],
    "SubagentStart": [],
    "SubagentStop": [],
    "UserPromptSubmit": []
  },
  "disabledMcpServers": [
    "mongodb",
    "mysql",
    "postgresql",
    "sqlite"
  ]
}
