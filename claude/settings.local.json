{
  "enabledMcpjsonServers": [
    "figma",
    "github",
    "atlassian",
    "mcp-manager",
    "postgresql",
    "mysql",
    "mongodb",
    "sqlite"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/scripts/log_tools_call.py",
            "description": "Log the tool usage to a file for auditing purposes."
          },
          {
            "type": "command",
            "command": ".claude/hooks/scripts/protect_files.py",
            "description": "Protect sensitive files from being modified or deleted."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/scripts/quality_gate.py",
            "description": "Run quality gate checks after tool usage."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/scripts/session_start.py",
            "description": "Log the session start to a file for auditing purposes."
          },
          {
            "type": "command",
            "command": ".claude/hooks/scripts/memory.py",
            "description": "Provide useful memory for agents, such as relevant documentation files in the repository and the latest session information."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/scripts/session_end.py",
            "description": "Log the session end to a file for auditing purposes."
          }
        ]
      }
    ],
    "PreCompact": [],
    "SubagentStart": [],
    "SubagentStop": [],
    "UserPromptSubmit": []
  }
}