{
  "mcpServers": {
    "figma": {
      "url": "https://mcp.figma.com/mcp",
      "type": "http"
    },
    "github-L": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_PAT_TOKEN_L:-add-value-to-env-vars}"
      }
    },
    "atlassian": {
      "type": "http",
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "mcp-manager": {
      "command": "/home/ronnas/develop/personal/mcp-manager/venv/bin/mcp-manager",
      "args": [
        "--config",
        "/home/ronnas/develop/personal/mcp-manager/backends.json",
        "--catalog",
        "/home/ronnas/develop/personal/mcp-manager/catalog.json",
        "--transport",
        "stdio"
      ],
      "type": "stdio"
    },
    "postgresql": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/Ronnasayd/AI-pair-programming.git#subdirectory=src",
        "postgresql-mcp"
      ],
      "env": {
        "POSTGRES_URL": "${MCP_POSTGRES_URL:-add-value-to-env-vars}"
      }
    },
    "mysql": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/Ronnasayd/AI-pair-programming.git#subdirectory=src",
        "mysql-mcp"
      ],
      "env": {
        "MYSQL_URL": "${MCP_MYSQL_URL:-add-value-to-env-vars}"
      }
    },
    "mongodb": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/Ronnasayd/AI-pair-programming.git#subdirectory=src",
        "mongodb-mcp"
      ],
      "env": {
        "MONGODB_URL": "${MCP_MONGODB_URL:-add-value-to-env-vars}",
        "MONGODB_DATABASE": "${MCP_MONGODB_DATABASE:-add-value-to-env-vars}"
      }
    },
    "sqlite": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/Ronnasayd/AI-pair-programming.git#subdirectory=src",
        "sqlite-mcp"
      ],
      "env": {
        "SQLITEDB_PATH": "${MCP_SQLITEDB_PATH:-add-value-to-env-vars}"
      }
    },
    "skill-loader": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/Ronnasayd/AI-pair-programming.git#subdirectory=src",
        "skill-loader-mcp"
      ]
    },
    "keycloak": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/Ronnasayd/keycloak-mcp-server",
        "keycloak-mcp-server"
      ],
      "env": {
        "MCP_KEYCLOAK_BASE_URL": "${MCP_KEYCLOAK_BASE_URL:-http://localhost:8080}",
        "MCP_KEYCLOAK_AUTH_METHOD": "${MCP_KEYCLOAK_AUTH_METHOD:-client_credentials}",
        "MCP_KEYCLOAK_CLIENT_ID": "${MCP_KEYCLOAK_CLIENT_ID:-add-value-to-env-vars}",
        "MCP_KEYCLOAK_CLIENT_SECRET": "${MCP_KEYCLOAK_CLIENT_SECRET:-add-value-to-env-vars}",
        "MCP_KEYCLOAK_ADMIN_USERNAME": "${MCP_KEYCLOAK_ADMIN_USERNAME:-add-value-to-env-vars}",
        "MCP_KEYCLOAK_ADMIN_PASSWORD": "${MCP_KEYCLOAK_ADMIN_PASSWORD:-add-value-to-env-vars}"
      }
    },
    "gcloud": {
      "command": "npx",
      "args": [
        "-y",
        "@google-cloud/gcloud-mcp"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "${CONTEXT7_API_KEY:-add-value-to-env-vars}"
      ]
    },
    "expo": {
      "type": "http",
      "url": "https://mcp.expo.dev/mcp"
    },
    "mobile-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@mobilenext/mobile-mcp@latest"
      ],
      "env": {
        "MOBILEMCP_DISABLE_TELEMETRY": "1"
      }
    }
  }
}