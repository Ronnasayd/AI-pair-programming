{
  "mcpServers": {
    "figma": {
      "url": "https://mcp.figma.com/mcp",
      "type": "http"
    },
    "github-L": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_PAT_TOKEN_L:-github_pat_token_not_set}"
      }
    },
    "atlassian": {
      "type": "http",
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "mcp-manager": {
      "command": "/home/ronnas/develop/personal/mcp-manager/venv/bin/mcp-manager",
      "args": [
        "--config",
        "/home/ronnas/develop/personal/mcp-manager/backends.json",
        "--catalog",
        "/home/ronnas/develop/personal/mcp-manager/catalog.json",
        "--transport",
        "stdio"
      ],
      "type": "stdio"
    },
    "postgresql": {
      "type": "stdio",
      "command": "/home/ronnas/develop/personal/AI-pair-programming/src/mcps/postgresql_mcp.py",
      "args": [],
      "env": {
        "POSTGRES_URL": "${MCP_POSTGRES_URL:-add-value-to-env-vars}"
      }
    },
    "mysql": {
      "type": "stdio",
      "command": "/home/ronnas/develop/personal/AI-pair-programming/src/mcps/mysql_mcp.py",
      "args": [],
      "env": {
        "MYSQL_URL": "${MCP_MYSQL_URL:-add-value-to-env-vars}"
      }
    },
    "mongodb": {
      "type": "stdio",
      "command": "/home/ronnas/develop/personal/AI-pair-programming/src/mcps/mongodb_mcp.py",
      "args": [],
      "env": {
        "MONGODB_URL": "${MCP_MONGODB_URL:-add-value-to-env-vars}",
        "MONGODB_DATABASE": "${MCP_MONGODB_DATABASE:-add-value-to-env-vars}"
      }
    },
    "sqlite": {
      "type": "stdio",
      "command": "/home/ronnas/develop/personal/AI-pair-programming/src/mcps/sqlite_mcp.py",
      "args": [],
      "env": {
        "SQLITEDB_PATH": "${MCP_SQLITEDB_PATH:-add-value-to-env-vars}"
      }
    }
  }
}