{
  "refresh_after": 20,
  "git_repo_url": "https://github.com/Ronnasayd/AI-pair-programming.git",
  "rules": [
    {
      "glob": "*.ts,*.js,*.py,*.java,*.go,*.css,*.cpp,*.c,*.vue,*.jsx,*.tsx",
      "refs": ["instructions/code.instructions.md"]
    },
    {
      "glob": "*.ts,*.js,*.jsx,*.tsx",
      "refs": ["instructions/jsdocs.instructions.md"]
    },
    {
      "glob": "*.openapi.ts",
      "refs": ["instructions/openapi.instructions.md"]
    },
    {
      "glob": "*.jsx,*.tsx",
      "refs": ["instructions/react.instructions.md"]
    },
    {
      "glob": "*.test.ts,*.test.js,*.spec.ts,*.spec.js",
      "refs": ["instructions/test.instructions.md"]
    },
    {
      "glob": "*.vue",
      "refs": ["instructions/vue.instructions.md"]
    },
    {
      "glob": "*.py",
      "refs": ["instructions/python.instructions.md"]
    },
    {
      "glob": "*.py",
      "refs": ["instructions/pydocs.instructions.md"]
    }
  ]
}
