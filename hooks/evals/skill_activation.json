{
  "hook": "scripts/skill_activation.py",
  "description": "Eval cases for skill_activation.py (UserPromptSubmit skill-suggestion hook)",
  "cases": [
    {
      "name": "no_prompt_key_no_output",
      "input": { "session_id": "evalnop1" },
      "expect_output": false
    },
    {
      "name": "empty_prompt_no_output",
      "input": { "prompt": "", "session_id": "evalnop2" },
      "expect_output": false
    },
    {
      "name": "malformed_json_no_output",
      "raw_stdin": "{not valid json",
      "expect_output": false
    },
    {
      "name": "empty_stdin_no_output",
      "raw_stdin": "",
      "expect_output": false
    },
    {
      "name": "merge_conflict_prompt_matches_skill",
      "input": {
        "prompt": "how do I resolve git merge conflicts",
        "session_id": "evalmerge"
      },
      "expect_output": true,
      "expect_pattern": "resolve-merge-conflicts"
    },
    {
      "name": "unrelated_gibberish_prompt_no_output",
      "input": {
        "prompt": "purple elephant quantum sandwich yesterday",
        "session_id": "evalgib1"
      },
      "expect_output": false
    },
    {
      "name": "dedup_suppresses_repeat_within_window",
      "input": {
        "prompt": "how do I resolve git merge conflicts",
        "session_id": "evalmerge"
      },
      "expect_output": false,
      "reset_rec_log": false
    }
  ]
}
