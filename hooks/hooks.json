{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": ".github/hooks/scripts/log_tools_call.py",
        "description": "Log the tool usage to a file for auditing purposes."
      },
      {
        "type": "command",
        "command": ".github/hooks/scripts/protect_files.py",
        "description": "Protect sensitive files from being modified or deleted."
      }
    ],
    "PostToolUse": [],
    "SessionStart": [
      {
        "type": "command",
        "command": ".github/hooks/scripts/session_start.py",
        "description": "Log the session start to a file for auditing purposes."
      }
    ],
    "Stop": [],
    "PreCompact": [],
    "SubagentStart": [],
    "SubagentStop": [],
    "UserPromptSubmit": []
  }
}