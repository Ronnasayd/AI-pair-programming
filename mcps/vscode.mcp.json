{
  "inputs": [
    {
      "type": "promptString",
      "id": "pg_url",
      "description": "PostgreSQL URL (e.g. postgresql://user:pass@host.docker.internal:5432/mydb)"
    }
  ],
  "servers": {
    "figma": {
      "url": "https://mcp.figma.com/mcp",
      "type": "http"
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "atlassian": {
      "type": "http",
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "mcp-manager": {
      "command": "/home/ronnas/develop/personal/mcp-manager/venv/bin/mcp-manager",
      "args": [
        "--config",
        "/home/ronnas/develop/personal/mcp-manager/backends.json",
        "--catalog",
        "/home/ronnas/develop/personal/mcp-manager/catalog.json",
        "--transport",
        "stdio"
      ],
      "type": "stdio"
    },
    "postgresql": {
      "type": "stdio",
      "command": "/home/ronnas/develop/personal/AI-pair-programming/src/mcps/postgresql.py",
      "args": [],
      "env": {
        "POSTGRES_URL": "${input:pg_url}"
      }
    }
  }
}