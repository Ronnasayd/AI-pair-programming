{
  "mcpServers": {
    "figma": {
      "url": "https://mcp.figma.com/mcp",
      "type": "http"
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "atlassian": {
      "type": "http",
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "mcp-manager": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/Ronnasayd/mcp-manager.git",
        "mcp-manager",
        "--config",
        "/home/ronnas/develop/personal/mcp-manager/backends.json",
        "--catalog",
        "/home/ronnas/develop/personal/mcp-manager/catalog.json",
        "--transport",
        "stdio"
      ],
      "type": "stdio"
    },
    "postgresql": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/Ronnasayd/AI-pair-programming.git#subdirectory=src",
        "postgresql-mcp"
      ],
      "env": {
        "POSTGRES_URL": "$POSTGRES_URL"
      }
    },
    "mysql": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/Ronnasayd/AI-pair-programming.git#subdirectory=src",
        "mysql-mcp"
      ],
      "env": {
        "MYSQL_URL": "$MYSQL_URL"
      }
    },
    "mongodb": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/Ronnasayd/AI-pair-programming.git#subdirectory=src",
        "mongodb-mcp"
      ],
      "env": {
        "MONGODB_URL": "$MONGODB_URL",
        "MONGODB_DATABASE": "$MONGODB_DATABASE"
      }
    },
    "sqlite": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/Ronnasayd/AI-pair-programming.git#subdirectory=src",
        "sqlite-mcp"
      ],
      "env": {
        "SQLITEDB_PATH": "$SQLITEDB_PATH"
      }
    }
  }
}